# backend/.env

# --- Required for Security/Authentication ---
# Generate a long, random string for production environments!
SECRET_KEY="your-super-secret-key-placeholder" 

# Algorithm used for JWT token signing (e.g., HS256, RS256)
ALGORITHM="HS256"

# --- Required for Database Connection ---
# Replace with your actual database URL (e.g., PostgreSQL, SQLite, MySQL)
# For local SQLite development, you can use:
DATABASE_URL="sqlite:///./gopam_dev.db"

# --- Optional: Project Info (If needed by your Settings model) ---
# PROJECT_NAME="Gopam API"
# VERSION="1.0.0"
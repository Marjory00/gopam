{
  "extends": [
    "development"
  ],
  "browserslist": [
    "defaults",
    "not IE 11",
    "last 2 versions",
    "not dead",
    "not < 0.2%"
  ],
  "hints": {
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off"
      }
    ],
    "axe/structure": [
      "default",
      {
        "list": "off"
      }
    ],
    "axe/aria": [
      "default",
      {
        "aria-valid-attr-value": "off"
      }
    ]
  }
}
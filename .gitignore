# .gitignore for Gopam Project

# -----------------
# Project-wide
# -----------------
# Ignore the main README and project file list
# README.md
# Docker setup files
docker-compose.yml
Dockerfile*

# -----------------
# Python/FastAPI (backend/)
# -----------------
# Virtual environment
/backend/venv/
/backend/__pycache__/
/backend/*.pyc
/backend/.env               # Local environment variables
/backend/instance/          # Flask/Alembic instance folder
/backend/.pytest_cache

# Database Migration files (Alembic)
/backend/alembic.ini
/database/migrations/versions/

# -----------------
# Node/Next.js (frontend/)
# -----------------
# Dependencies
/frontend/node_modules
/frontend/.npm

# Dependency lock files
/frontend/package-lock.json
/frontend/npm-debug.log
/frontend/yarn.lock*
/frontend/pnpm-lock.yaml

# Production and build outputs
/frontend/.next/
/frontend/out/
/frontend/dist/

# Logs
/frontend/npm-debug.log*
/frontend/yarn-error.log

# Local environment files
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.production.local
/frontend/.env.staging.local

# TypeScript cache
/frontend/.tsbuildinfo

# -----------------
# IDE/Editor files
# -----------------
.vscode/
.idea/

# -----------------
# Operating System
# -----------------
.DS_Store
Thumbs.db